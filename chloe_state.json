    {
      "from": "chloe",
      "text": "(something went quiet: Error code: 401 - {'type': 'error', 'error': {'type': 'authentication_error', 'message': 'invalid x-api-key'}, 'request_id': 'req_011CZyz7QL2Bay4d53mx3csL'})",
